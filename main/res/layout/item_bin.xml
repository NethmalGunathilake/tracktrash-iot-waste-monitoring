<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@android:color/white"
    android:foreground="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- Bin Icon -->
        <androidx.cardview.widget.CardView
            android:id="@+id/binIconContainer"
            android:layout_width="56dp"
            android:layout_height="56dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#F0F4F8"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/binIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="🗂️"
                android:textSize="24sp"
                android:gravity="center" />

        </androidx.cardview.widget.CardView>

        <!-- Bin Name -->
        <TextView
            android:id="@+id/binIdTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Bin 01"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintStart_toEndOf="@id/binIconContainer"
            app:layout_constraintTop_toTopOf="@id/binIconContainer"
            app:layout_constraintEnd_toStartOf="@id/fillLevelContainer"
            tools:text="Bin 01" />

        <!-- Bin Status -->
        <TextView
            android:id="@+id/binStatusTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Active • Last updated 2 min ago"
            android:textSize="14sp"
            android:textColor="#757575"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="4dp"
            app:layout_constraintStart_toEndOf="@id/binIconContainer"
            app:layout_constraintTop_toBottomOf="@id/binIdTextView"
            app:layout_constraintEnd_toStartOf="@id/fillLevelContainer"
            tools:text="Active • Last updated 2 min ago" />

        <!-- Fill Level Container - IMPROVED VERSION -->
        <LinearLayout
            android:id="@+id/fillLevelContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- Fill Level Progress Circle - LARGER AND MORE VISIBLE -->
            <androidx.cardview.widget.CardView
                android:id="@+id/fillLevelProgressContainer"
                android:layout_width="64dp"
                android:layout_height="64dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/fillLevelTextView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/percentage_background"
                    android:gravity="center"
                    android:text="94%"
                    android:textColor="#FFFFFF"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    tools:text="94%" />

            </androidx.cardview.widget.CardView>

            <!-- Fill Level Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fill Level"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#757575"
                android:gravity="center" />

        </LinearLayout>

        <!-- Status Indicator (colored line at bottom) -->
        <View
            android:id="@+id/statusIndicator"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:background="#4CAF50"
            android:layout_marginTop="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/binIconContainer"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>